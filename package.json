{
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 61303",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 61303",
    "typecheck": "tsc -b",
    "typecheck:watch": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:check": "npm run typecheck && npm run test",
    "prebuild": "npm run ci:check",
    "prepack": "npm run ci:check"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
